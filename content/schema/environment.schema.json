{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nullhorizon.local/schema/environment.schema.json",
  "title": "Environment",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "template_id", "seed"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "template_id": { "type": "string", "minLength": 1 },
    "seed": { "type": "integer" },
    "initial_state": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "effects"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "requires": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean"]
            }
          },
          "effects": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": ["string", "number", "boolean"]
            }
          }
        }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "target", "editable"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "editable": { "type": "boolean" }
        }
      }
    },
    "filesystem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cwd", "entries"],
      "properties": {
        "cwd": {
          "type": "string",
          "pattern": "^/"
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "type"],
            "properties": {
              "path": {
                "type": "string",
                "pattern": "^/"
              },
              "type": {
                "type": "string",
                "enum": ["dir", "file"]
              },
              "content": { "type": "string" }
            },
            "allOf": [
              {
                "if": {
                  "properties": { "type": { "const": "file" } }
                },
                "then": {
                  "required": ["content"]
                }
              }
            ]
          }
        }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial_branch", "commits"],
      "properties": {
        "initial_branch": { "type": "string", "minLength": 1 },
        "branches": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "working_tree": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "commits": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["message", "author"],
            "properties": {
              "id": { "type": "string" },
              "message": { "type": "string", "minLength": 1 },
              "author": { "type": "string", "minLength": 1 },
              "parent": { "type": "string" },
              "parents": {
                "type": "array",
                "items": { "type": "string" }
              },
              "files": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "databases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "seed_sql"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "policy": {
            "type": "string",
            "enum": ["select_only"]
          },
          "seed_sql": { "type": "string", "minLength": 1 },
          "seed_file": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
