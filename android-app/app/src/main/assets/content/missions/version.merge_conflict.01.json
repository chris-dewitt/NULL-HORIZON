  },
  "objectives": [
    {
      "assert": {
        "conflict_count": 1,
        "last_command": "git merge repair",
        "stdout_contains": "CONFLICT"
      },
      "description": "Merge repair into main and produce a conflict on power.policy.",
      "id": "start_merge",
      "type": "git_state",
      "visible": true
    },
    {
      "assert": {
        "file_equals:power.policy": "bus_a=online\nbus_b=online\n"
      },
      "description": "Resolve power.policy using the repair branch (theirs) values.",
      "id": "resolve_theirs",
      "type": "git_state",
      "visible": true
    },
    {
      "assert": {
        "conflict_count": 0,
        "file_equals:power.policy": "bus_a=online\nbus_b=online\n",
        "head_message_contains": "Merge",
        "working_tree_clean": true
      },
      "description": "Stage the resolution and commit the merge.",
      "id": "finish_merge",
      "type": "git_state",
      "visible": true
    }
  ],
