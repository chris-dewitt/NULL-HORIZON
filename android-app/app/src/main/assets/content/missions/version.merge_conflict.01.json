  "hints": [
    {
      "level": 1,
      "text": "You are on main. Merge with git merge repair."
    },
    {
      "level": 2,
      "text": "Use the conflict UI or git checkout --theirs power.policy."
    },
    {
      "level": 3,
      "text": "Stage the resolved file with git add power.policy."
    },
    {
      "level": 4,
      "text": "Finish with git commit -m \"Merge branch 'repair'\"."
    }
