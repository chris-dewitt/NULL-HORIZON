{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nullhorizon.local/schema/environment.schema.json",
  "title": "Environment",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "template_id", "seed"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "template_id": { "type": "string", "minLength": 1 },
    "seed": { "type": "integer" },
    "initial_state": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "effects"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "requires": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean"]
            }
          },
          "effects": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": ["string", "number", "boolean"]
            }
          }
        }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "target", "editable"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "editable": { "type": "boolean" }
        }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files"],
      "properties": {
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "editable", "content"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "editable": { "type": "boolean" },
              "content": { "type": "string" },
              "source": { "type": "string" }
            }
          }
        },
        "execution": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "fixtures"],
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["fake"]
            },
            "fixtures": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "result"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "match": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "file_contains": {
                        "type": "object",
                        "additionalProperties": { "type": "string" }
                      },
                      "file_equals": {
                        "type": "object",
                        "additionalProperties": { "type": "string" }
                      }
                    }
                  },
                  "result": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["status", "tests"],
                    "properties": {
                      "status": { "type": "string" },
                      "stdout": { "type": "string" },
                      "stderr": { "type": "string" },
                      "tests": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["id", "status"],
                          "properties": {
                            "id": { "type": "string" },
                            "status": {
                              "type": "string",
                              "enum": ["passed", "failed", "skipped", "error"]
                            },
                            "message": { "type": "string" },
                            "expected": { "type": "string" },
                            "actual": { "type": "string" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "filesystem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cwd", "entries"],
      "properties": {
        "cwd": {
          "type": "string",
          "pattern": "^/"
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "type"],
            "properties": {
              "path": {
                "type": "string",
                "pattern": "^/"
              },
              "type": {
                "type": "string",
                "enum": ["dir", "file"]
              },
              "content": { "type": "string" }
            },
            "allOf": [
              {
                "if": {
                  "properties": { "type": { "const": "file" } }
                },
                "then": {
                  "required": ["content"]
                }
              }
            ]
          }
        },
        "processes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pid", "name"],
            "properties": {
              "pid": { "type": "integer", "minimum": 1 },
              "name": { "type": "string", "minLength": 1 },
              "status": {
                "type": "string",
                "enum": ["running", "stopped"]
              },
              "command": { "type": "string" }
            }
          }
        }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial_branch", "commits"],
      "properties": {
        "initial_branch": { "type": "string", "minLength": 1 },
        "branches": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "working_tree": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "commits": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["message", "author"],
            "properties": {
              "id": { "type": "string" },
              "message": { "type": "string", "minLength": 1 },
              "author": { "type": "string", "minLength": 1 },
              "parent": { "type": "string" },
              "parents": {
                "type": "array",
                "items": { "type": "string" }
              },
              "files": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "databases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "seed_sql"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "policy": {
            "type": "string",
            "enum": ["select_only"]
          },
          "seed_sql": { "type": "string", "minLength": 1 },
          "seed_file": { "type": "string", "minLength": 1 }
        }
      }
    },
    "service_map": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes"],
      "properties": {
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/graph_node" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/graph_edge" }
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/graph_action" }
        }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes"],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/graph_node" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/graph_edge" }
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/graph_action" }
        }
      }
    },
    "mlops": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts"],
      "properties": {
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind", "label"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "kind": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 },
              "stage": { "type": "string" },
              "status": { "type": "string" },
              "version": { "type": "string" },
              "detail": { "type": "string" }
            }
          }
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/graph_action" }
        }
      }
    }
  },
  "$defs": {
    "graph_node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "label"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "status": { "type": "string" },
        "detail": { "type": "string" }
      }
    },
    "graph_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from", "to"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "kind": { "type": "string" },
        "status": { "type": "string" },
        "detail": { "type": "string" }
      }
    },
    "graph_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "effects"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "requires": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        },
        "effects": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        }
      }
    }
  }
}
