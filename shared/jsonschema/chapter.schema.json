{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nullhorizon.local/schema/chapter.schema.json",
  "title": "Chapter",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "chapter_id", "title", "region", "mission_ids"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "chapter_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "region": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "mission_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
